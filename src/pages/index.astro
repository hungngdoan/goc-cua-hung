---
import Base from '../layouts/Base.astro';

const navItems = ["Alpha", "Bravo", "Charlie", "Delta", "Echo", "Foxtrot", "Gamma", "Helix", "Indigo"];

const posts = [
  {
    title: "Placeholder Article One",
    date: "Month 00, 0000",
    type: "Sample category",
    seal: "One",
    body: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vitae velit at sapien varius blandit.",
  },
  {
    title: "Placeholder Article Two",
    date: "Month 00, 0000",
    type: "Sample note",
    seal: "Two",
    body: "Praesent commodo libero non lectus facilisis, sed tempor mi luctus. Cras posuere sem a nibh gravida.",
  },
  {
    title: "Placeholder Article Three",
    date: "Month 00, 0000",
    type: "Sample update",
    seal: "Tre",
    body: "Aliquam erat volutpat. Donec vitae arcu nec justo dictum pretium quis a augue.",
  },
];

const quests = [
  { name: "Placeholder task one", done: true },
  { name: "Placeholder task two", done: true },
  { name: "Placeholder task three", done: true },
  { name: "Placeholder task four", done: true },
  { name: "Placeholder task five", done: false },
  { name: "Placeholder task six", done: false },
];
---

<Base title="Placeholder Page">
  <main
    class="min-h-screen"
    style="color: #ffe7b3; background-color: #28140d; background-image: radial-gradient(circle at 18% 12%, rgba(244,184,96,.24), transparent 16%), radial-gradient(circle at 78% 8%, rgba(209,75,51,.18), transparent 18%), linear-gradient(90deg, rgba(244,184,96,.06) 1px, transparent 1px);"
  >
    <div class="mx-auto max-w-6xl px-4 py-5 sm:px-7 lg:px-8">
      <div
        class="border-[3px] border-double p-2"
        style="border-color: rgba(255,231,179,0.35); background: rgba(255,231,179,0.025);"
      >
        <div class="border p-4 sm:p-6 lg:p-8" style="border-color: rgba(255,231,179,0.20);">

          <header class="grid gap-6 lg:grid-cols-[1fr_260px] lg:items-start">
            <div>
              <div
                class="inline-block border px-3 py-1 text-xs uppercase tracking-[0.26em]"
                style="border-color: rgba(255,231,179,0.30); color: rgba(255,231,179,0.75); box-shadow: 3px 3px 0 rgba(0,0,0,.08);"
              >
                Placeholder Label
              </div>
              <h1 class="mt-5 max-w-4xl font-serif text-5xl font-black leading-[1.02] tracking-tight sm:text-7xl lg:text-8xl">
                Placeholder headline for a page still being written
              </h1>
              <p class="mt-5 max-w-2xl font-serif text-lg leading-8" style="color: rgba(255,231,179,0.75);">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Curabitur posuere, mi sed facilisis varius, nunc massa tempor arcu, vitae placerat neque justo sed lorem.
              </p>
            </div>

            <aside
              class="border p-4"
              style="background: rgba(58,29,18,0.88); border-color: rgba(244,184,96,0.35); box-shadow: 6px 6px 0 rgba(0,0,0,.10);"
            >
              <div class="text-center font-serif text-2xl font-black">Name</div>
              <div
                class="mx-auto mt-2 grid h-20 w-20 place-items-center rounded-full border-4 border-double text-xl font-black tracking-tight"
                style="border-color: rgba(255,231,179,0.40); background: rgba(0,0,0,0.04); color: #f4b860;"
              >
                N
              </div>
              <p class="mt-3 text-center text-sm leading-6" style="color: rgba(255,231,179,0.75);">
                Placeholder description for a short profile, bio, or personal note.
              </p>
              <div class="my-5 flex items-center gap-3 opacity-80">
                <div class="h-px flex-1" style="background: #f4b860;"></div>
                <div class="text-xs tracking-[0.35em]" style="color: #f4b860;">◇ ◇ ◇</div>
                <div class="h-px flex-1" style="background: #f4b860;"></div>
              </div>
              <div class="grid grid-cols-2 gap-2">
                {[{l:"Item",v:"00"},{l:"Mode",v:"Text"},{l:"Stat",v:"000"},{l:"Goal",v:"Plan"}].map(s => (
                  <div class="border p-3" style="background: rgba(0,0,0,0.025); border-color: rgba(255,231,179,0.25); box-shadow: 4px 4px 0 rgba(0,0,0,.08);">
                    <div class="text-[11px] uppercase tracking-[0.18em]" style="color: rgba(255,231,179,0.60);">{s.l}</div>
                    <div class="mt-1 text-lg font-bold">{s.v}</div>
                  </div>
                ))}
              </div>
            </aside>
          </header>

          <nav
            class="mt-6 grid grid-cols-3 gap-2 border-y py-3 text-center text-sm font-semibold sm:grid-cols-9"
            style="border-color: rgba(255,231,179,0.25);"
          >
            {navItems.map(item => (
              <button
                class="border px-2 py-2 transition hover:translate-y-[-1px]"
                style="border-color: rgba(255,231,179,0.20); background: rgba(0,0,0,0.02); color: rgba(255,231,179,0.75);"
              >
                {item}
              </button>
            ))}
          </nav>

          <section class="mt-6 grid gap-5 lg:grid-cols-[310px_1fr]">
            <aside class="space-y-5">
              <section
                class="border p-4"
                style="background: rgba(58,29,18,0.88); border-color: rgba(244,184,96,0.35); box-shadow: 6px 6px 0 rgba(0,0,0,.10);"
              >
                <div class="font-serif text-xl font-black">Placeholder Block</div>
                <p class="mt-2 text-sm leading-6" style="color: rgba(255,231,179,0.75);">
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer tincidunt lorem in quam feugiat.
                </p>
                <a
                  href={`${import.meta.env.BASE_URL}/style-lab/`}
                  class="mt-4 inline-block border px-4 py-2 text-sm font-bold transition hover:translate-x-0.5"
                  style="border-color: #f4b860; color: #f4b860; box-shadow: 3px 3px 0 rgba(0,0,0,.10);"
                >
                  placeholder link →
                </a>
              </section>

              <section
                class="border p-4"
                style="background: rgba(81,35,21,0.55); border-color: rgba(244,184,96,0.25); box-shadow: 6px 6px 0 rgba(0,0,0,.10);"
              >
                <div class="font-serif text-xl font-black">Placeholder Title</div>
                <div
                  class="mt-3 border-y py-3 text-2xl font-black"
                  style="border-color: rgba(255,231,179,0.15);"
                >
                  Sample Text
                </div>
                <p class="mt-2 text-sm" style="color: rgba(255,231,179,0.75);">
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                </p>
              </section>

              <section
                class="border p-4"
                style="background: rgba(81,35,21,0.55); border-color: rgba(244,184,96,0.25); box-shadow: 6px 6px 0 rgba(0,0,0,.10);"
              >
                <div class="font-serif text-xl font-black">Placeholder List</div>
                <div class="mt-3 space-y-2">
                  {quests.map(q => (
                    <div
                      class="flex items-center justify-between border-b pb-2 text-sm"
                      style="border-color: rgba(255,231,179,0.15);"
                    >
                      <span>{q.name}</span>
                      <span class="font-bold" style={q.done ? "color: #f4b860;" : ""}>
                        {q.done ? "done" : "open"}
                      </span>
                    </div>
                  ))}
                </div>
              </section>
            </aside>

            <section class="space-y-4">
              {posts.map(post => (
                <article
                  class="grid gap-4 border p-4 sm:grid-cols-[84px_1fr] sm:p-5"
                  style="background: rgba(81,35,21,0.55); border-color: rgba(244,184,96,0.25); box-shadow: 6px 6px 0 rgba(0,0,0,.10);"
                >
                  <div class="flex sm:block sm:text-center">
                    <div
                      class="grid h-16 w-16 shrink-0 place-items-center border-4 border-double font-serif text-sm font-black"
                      style="color: #f4b860; border-color: rgba(255,231,179,0.35);"
                    >
                      {post.seal}
                    </div>
                    <div class="ml-3 sm:ml-0 sm:mt-3">
                      <div class="text-xs uppercase tracking-[0.2em]" style="color: rgba(255,231,179,0.60);">{post.type}</div>
                      <div class="mt-1 text-xs" style="color: rgba(255,231,179,0.60);">{post.date}</div>
                    </div>
                  </div>
                  <div>
                    <h3 class="font-serif text-2xl font-black sm:text-3xl">{post.title}</h3>
                    <p class="mt-3 max-w-3xl text-base leading-8" style="color: rgba(255,231,179,0.75);">{post.body}</p>
                    <button
                      class="mt-4 border px-4 py-2 text-sm font-bold transition hover:translate-x-0.5"
                      style="border-color: #f4b860; color: #f4b860; box-shadow: 3px 3px 0 rgba(0,0,0,.10);"
                    >
                      read more →
                    </button>
                  </div>
                </article>
              ))}
            </section>
          </section>

          <footer class="mt-7 border-t pt-5" style="border-color: rgba(255,231,179,0.25);">
            <div class="grid gap-4 sm:grid-cols-[1fr_2fr]">
              <div
                class="border p-4"
                style="background: rgba(81,35,21,0.55); border-color: rgba(244,184,96,0.25); box-shadow: 5px 5px 0 rgba(0,0,0,.10);"
              >
                <div class="font-serif text-xl font-black">Placeholder Footer</div>
                <p class="mt-2 leading-7" style="color: rgba(255,231,179,0.75);">
                  "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse vitae tellus sed lorem."
                </p>
              </div>
              <div
                class="border p-4"
                style="background: rgba(81,35,21,0.55); border-color: rgba(244,184,96,0.25); box-shadow: 5px 5px 0 rgba(0,0,0,.10);"
              >
                <div class="font-serif text-xl font-black">Placeholder Notes</div>
                <p class="mt-2 leading-7" style="color: rgba(255,231,179,0.75);">
                  Lorem ipsum dolor sit amet, consectetur adipiscing elit. Maecenas suscipit sem vitae sapien rhoncus, non posuere neque tempor.
                </p>
              </div>
            </div>
            <div class="mt-5 text-center text-xs uppercase tracking-[0.35em]" style="color: rgba(255,231,179,0.60);">
              ◆  placeholder  ◆  sample  ◆  text  ◆
            </div>
          </footer>

        </div>
      </div>
    </div>
  </main>
</Base>
